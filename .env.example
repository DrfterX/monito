# Copy this file to .env and fill in your values
# cp .env.example .env

# Cloudflare API Token (needed for wrangler deploy)
# Create at: https://dash.cloudflare.com/profile/api-tokens
# Permissions needed: Workers (Write), D1 (Write), KV (Write), Pages (Write)
CLOUDFLARE_API_TOKEN=

# Default alert email for all monitors (overridable per monitor)
DEFAULT_ALERT_FROM=monito@yourdomain.com
ALERT_EMAIL=you@example.com

# Resend API Key for email alerts
# Get at: https://resend.com/api-keys
RESEND_API_KEY=

# Monito API Key (for CLI authentication)
# Generate a random string: openssl rand -hex 32
MONITO_API_KEY=
